# ─── Database ────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:your_password@localhost:5432/student_app?schema=public"

# ─── Session ─────────────────────────────────────────────────────
SESSION_SECRET="change-me-to-a-random-string-at-least-32-chars"

# ─── File Storage ────────────────────────────────────────────────
# For V1 local dev, files are stored on disk under ./uploads
# Swap to S3/GCS by changing the adapter in lib/server/storage
STORAGE_ADAPTER="local"
UPLOAD_DIR="./uploads"

# ─── App ─────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
